---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Miami Springs Historical Society',
  description = 'Preserving the history of Miami Springs, Florida — founded by aviation pioneer Glenn Curtiss. Celebrating our centennial — 100 years of Miami Springs.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="MSHS Upcoming Events" href="/rss.xml" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#8b4513" />
    <link rel="canonical" href={Astro.url.href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Miami Springs Historical Society" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content="https://miamispringshistoricalsociety.com/curtiss-mansion-entrance.jpg" />
    <meta property="og:image:alt" content="The entrance of the Curtiss Mansion, Miami Springs" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Miami Springs Historical Society",
      "description": description,
      "url": "https://miamispringshistoricalsociety.com",
      "telephone": "(305) 884-4406",
      "email": "info@miamispringshistoricalsociety.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "501 East Drive",
        "addressLocality": "Miami Springs",
        "addressRegion": "FL",
        "postalCode": "33166",
        "addressCountry": "US"
      },
      "openingHours": "Sa 12:00-16:00",
      "sameAs": ["https://www.facebook.com/mspringshistory"]
    })} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://connect.facebook.net" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lora:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #8b4513;
    --color-primary-dark: #6b3410;
    --color-secondary: #d2b48c;
    --color-accent: #2c5f2d;
    --color-bg: #faf6f0;
    --color-bg-alt: #e8d8c4;
    --color-text: #2a1a0e;
    --color-text-muted: #6b5040;
    --font-display: 'Playfair Display', Georgia, serif;
    --font-body: 'Lora', Georgia, serif;
    --max-width: 1100px;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  h1,
  h2,
  h3,
  h4 {
    font-family: var(--font-display);
    line-height: 1.25;
  }

  img {
    max-width: 100%;
    display: block;
  }

  section:not(.hero) {
    background-image: radial-gradient(rgba(42, 26, 14, 0.05) 1px, transparent 1px);
    background-size: 3px 3px;
  }

  a {
    color: var(--color-primary);
  }

  a:hover {
    color: var(--color-accent);
  }

  :focus-visible {
    outline: 2px solid var(--color-secondary);
    outline-offset: 3px;
  }

  .section-title a {
    color: inherit;
    text-decoration: none;
  }

  .section-title a::after {
    content: ' #';
    opacity: 0;
    font-size: 0.65em;
    color: var(--color-secondary);
    transition: opacity 0.2s;
  }

  .section-title:hover a::after {
    opacity: 1;
  }

  .section-title a:hover {
    color: inherit;
  }
</style>
