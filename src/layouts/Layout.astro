---
interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = 'Miami Springs Historical Society',
  description = 'Preserving the history of Miami Springs, Florida — founded by aviation pioneer Glenn Curtiss. Celebrating our centennial — 100 years of Miami Springs.',
  lang = Astro.currentLocale ?? 'en',
} = Astro.props;

import { useTranslations } from '../i18n/utils';
const t = useTranslations(lang);

const site = 'https://miamispringshistoricalsociety.com';
const pathname = Astro.url.pathname;
const isEs = pathname.startsWith('/es');
const enPath = isEs ? (pathname.replace(/^\/es/, '') || '/') : pathname;
const esPath = isEs ? pathname : ('/es' + (pathname === '/' ? '' : pathname));
const enUrl = site + enPath;
const esUrl = site + esPath;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="MSHS Upcoming Events" href="/rss.xml" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#8b4513" />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Miami Springs Historical Society" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content="https://miamispringshistoricalsociety.com/curtiss-mansion-entrance.jpg" />
    <meta property="og:image:alt" content={t('hero.og_image_alt')} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://miamispringshistoricalsociety.com/curtiss-mansion-entrance.jpg" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Miami Springs Historical Society",
      "description": description,
      "url": "https://miamispringshistoricalsociety.com",
      "telephone": "(305) 884-4406",
      "email": "info@miamispringshistoricalsociety.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "501 East Drive",
        "addressLocality": "Miami Springs",
        "addressRegion": "FL",
        "postalCode": "33166",
        "addressCountry": "US"
      },
      "openingHours": "Sa 12:00-16:00",
      "sameAs": ["https://www.facebook.com/mspringshistory"]
    })} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://connect.facebook.net" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lora:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    {!isEs && <script is:inline>
      (function () {
        var cookies = document.cookie.split(';');
        for (var i = 0; i < cookies.length; i++) {
          var c = cookies[i].trim();
          if (c === 'lang=en') return;      // user explicitly chose English
          if (c.startsWith('lang=')) break; // any other explicit choice — stop
        }
        var lang = (navigator.language || navigator.userLanguage || '').split('-')[0].toLowerCase();
        if (lang === 'es') {
          var p = location.pathname;
          location.replace('/es' + (p === '/' ? '' : p));
        }
      })();
    </script>}
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --color-primary: #8b4513;
    --color-primary-dark: #6b3410;
    --color-secondary: #d2b48c;
    --color-accent: #2c5f2d;
    --color-bg: #faf6f0;
    --color-bg-alt: #e8d8c4;
    --color-text: #2a1a0e;
    --color-text-muted: #6b5040;
    --color-white: #fff;
    --color-nav-bg: rgba(42, 26, 14, 0.93);
    --color-nav-bg-mobile: rgba(42, 26, 14, 0.97);
    --color-overlay-dark: rgba(42, 26, 14, 0.82);
    --color-overlay-light: rgba(250, 246, 240, 0.88);
    --color-panel-text-light: rgba(250, 246, 240, 0.92);
    --color-panel-counter-light: rgba(250, 246, 240, 0.7);
    --color-panel-counter-dark: rgba(42, 26, 14, 0.6);
    --color-footer-text: rgba(250, 246, 240, 0.6);
    --color-eyebrow: #a8e6a9;
    --font-display: 'Playfair Display', Georgia, serif;
    --font-body: 'Lora', Georgia, serif;
    --max-width: 1100px;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  h1,
  h2,
  h3,
  h4 {
    font-family: var(--font-display);
    line-height: 1.25;
  }

  img {
    max-width: 100%;
    display: block;
  }

  section:not(.hero) {
    background-image:
      repeating-linear-gradient(45deg, rgba(42,26,14,0.04) 0px, rgba(42,26,14,0.04) 1px, transparent 1px, transparent 7px),
      repeating-linear-gradient(-45deg, rgba(42,26,14,0.04) 0px, rgba(42,26,14,0.04) 1px, transparent 1px, transparent 7px);
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    background: var(--color-primary);
    color: var(--color-bg);
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-family: var(--font-body);
    z-index: 9999;
    border-bottom: none;
  }

  .skip-link:focus {
    top: 1rem;
  }

  a {
    color: var(--color-primary);
    text-decoration: none;
  }

  a:hover {
    color: var(--color-accent);
  }

  /* Inline body links: two-factor (color + border-bottom) */
  p a {
    border-bottom: 1px solid var(--color-secondary);
    padding-bottom: 1px;
  }

  p a:hover {
    border-bottom-color: var(--color-accent);
  }

  :focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  .section-title a {
    color: inherit;
    text-decoration: none;
  }

  .section-title a::after {
    content: ' #';
    opacity: 0;
    font-size: 0.65em;
    color: var(--color-secondary);
    transition: opacity 0.2s;
  }

  .section-title:hover a::after {
    opacity: 1;
  }

  .section-title a:hover {
    color: inherit;
  }
</style>
