---
import { getCollection } from 'astro:content';

function nextSecondTuesday(startAfter?: Date): Date {
  const after = startAfter && startAfter > new Date() ? startAfter : new Date();
  for (let offset = 0; offset <= 3; offset++) {
    const year = after.getFullYear() + Math.floor((after.getMonth() + offset) / 12);
    const month = (after.getMonth() + offset) % 12;
    const first = new Date(year, month, 1);
    const daysUntilTuesday = (2 - first.getDay() + 7) % 7;
    const secondTuesday = new Date(year, month, 1 + daysUntilTuesday + 7, 16, 0, 0);
    if (secondTuesday > after) return secondTuesday;
  }
  const next = new Date(after.getFullYear(), after.getMonth() + 1, 1);
  const daysUntilTuesday = (2 - next.getDay() + 7) % 7;
  return new Date(next.getFullYear(), next.getMonth(), 1 + daysUntilTuesday + 7, 16, 0, 0);
}

const events = await getCollection('events');

// Resolve recurring events to their next occurrence date
const resolved = events.map(event => {
  if (event.data.recurring === 'monthly-second-tuesday') {
    return { ...event, data: { ...event.data, date: nextSecondTuesday(event.data.recurringStartAfter) } };
  }
  return event;
});

const sorted = resolved.sort((a, b) => a.data.date!.getTime() - b.data.date!.getTime());

const rendered = await Promise.all(
  sorted.map(async (event) => {
    const { Content } = await event.render();
    return { data: event.data, id: event.id, Content };
  })
);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'America/New_York',
  });

const formatMonth = (date: Date) =>
  date.toLocaleDateString('en-US', { month: 'short', timeZone: 'America/New_York' });

const formatDay = (date: Date) =>
  date.toLocaleDateString('en-US', { day: '2-digit', timeZone: 'America/New_York' });

const formatDateRange = (start: Date, end: Date) => {
  const opts: Intl.DateTimeFormatOptions = { month: 'long', day: 'numeric', timeZone: 'America/New_York' };
  const startStr = start.toLocaleDateString('en-US', opts);
  const endStr = end.toLocaleDateString('en-US', { day: 'numeric', timeZone: 'America/New_York' });
  const year = start.toLocaleDateString('en-US', { year: 'numeric', timeZone: 'America/New_York' });
  return `${startStr}–${endStr}, ${year}`;
};
---

<section id="events" class="events-section">
  <div class="container">
    <h2 class="section-title"><a href="#events">Events</a></h2>
    <div class="divider"></div>

    {rendered.length > 0 ? (
      <ul class="events-list">
        {rendered.map(({ data, Content }) => (
          <li
            class="event-card"
            data-recurring={data.recurring ?? 'false'}
            data-expiry={(data.endDate ?? data.date)!.toLocaleDateString('en-CA', { timeZone: 'America/New_York' })}
            data-recurring-start-after={data.recurringStartAfter?.toISOString().split('T')[0]}
          >
            <div class="event-date">
              <span class="event-month">{formatMonth(data.date)}</span>
              <span class="event-day">{formatDay(data.date)}</span>
            </div>
            <div class="event-info">
              <h3 class="event-title">{data.title}</h3>
              <p class="event-meta">
                <time datetime={data.date!.toISOString()}>
                  {data.endDate ? formatDateRange(data.date!, data.endDate) : formatDate(data.date!)}
                </time>
                {data.time && <> &mdash; {data.time}</>}
                {data.location && <><br />{data.location}</>}
                {data.price && <><br />{data.price}</>}
              </p>
              <div class="event-body">
                <Content />
              </div>
            </div>
          </li>
        ))}
      </ul>
    ) : (
      <p class="no-events">
        No events scheduled at this time. Follow us on Facebook for the latest announcements.
      </p>
    )}
  </div>
</section>

<script>
  function nextSecondTuesday(startAfter?: Date): Date {
    const now = new Date();
    const after = startAfter && startAfter > now ? startAfter : now;
    for (let offset = 0; offset <= 3; offset++) {
      const year = after.getFullYear() + Math.floor((after.getMonth() + offset) / 12);
      const month = (after.getMonth() + offset) % 12;
      const first = new Date(year, month, 1);
      const daysUntilTuesday = (2 - first.getDay() + 7) % 7;
      const secondTuesday = new Date(year, month, 1 + daysUntilTuesday + 7, 16, 0, 0);
      if (secondTuesday > after) return secondTuesday;
    }
    const next = new Date(after.getFullYear(), after.getMonth() + 1, 1);
    const daysUntilTuesday = (2 - next.getDay() + 7) % 7;
    return new Date(next.getFullYear(), next.getMonth(), 1 + daysUntilTuesday + 7, 16, 0, 0);
  }

  // Today's date in Eastern time as YYYY-MM-DD (en-CA locale gives this format)
  const todayET = new Date().toLocaleDateString('en-CA', { timeZone: 'America/New_York' });
  const cards = document.querySelectorAll<HTMLElement>('.event-card');
  let visible = 0;

  cards.forEach(card => {
    const recurring = card.dataset.recurring ?? 'false';
    const expiry = card.dataset.expiry ?? '';

    if (recurring === 'monthly-second-tuesday') {
      // Recalculate the next occurrence client-side so stale build dates auto-update
      const startAfterStr = card.dataset.recurringStartAfter;
      const startAfter = startAfterStr ? new Date(startAfterStr) : undefined;
      const next = nextSecondTuesday(startAfter);
      const monthEl = card.querySelector('.event-month');
      const dayEl = card.querySelector('.event-day');
      const timeEl = card.querySelector('time');
      if (monthEl) monthEl.textContent = next.toLocaleDateString('en-US', { month: 'short', timeZone: 'America/New_York' });
      if (dayEl) dayEl.textContent = next.toLocaleDateString('en-US', { day: '2-digit', timeZone: 'America/New_York' });
      if (timeEl) {
        timeEl.dateTime = next.toISOString();
        timeEl.textContent = next.toLocaleDateString('en-US', {
          weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
          timeZone: 'America/New_York',
        });
      }
      visible++;
    } else if (recurring !== 'false') {
      // Unknown recurring type — always show
      visible++;
    } else if (todayET > expiry) {
      card.style.display = 'none';
    } else {
      visible++;
    }
  });

  if (visible === 0) {
    const list = document.querySelector('.events-list') as HTMLElement;
    const fallback = document.querySelector<HTMLElement>('.no-events');
    if (list) list.style.display = 'none';
    if (fallback) fallback.style.display = 'block';
  }
</script>

<style>
  .events-section {
    padding: 5rem 0;
    background-color: var(--color-bg-alt);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 5vw, 2.25rem);
    color: var(--color-primary);
    margin-bottom: 1rem;
    text-align: center;
  }

  .divider {
    width: 60px;
    height: 3px;
    background-color: var(--color-secondary);
    margin: 0 auto 3rem;
  }

  .events-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 780px;
    margin: 0 auto;
  }

  .event-card {
    display: flex;
    gap: 2rem;
    background-color: var(--color-bg);
    border: 1px solid var(--color-primary);
    padding: 1.75rem 2rem;
    align-items: flex-start;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .event-date {
    flex-shrink: 0;
    text-align: center;
    background-color: var(--color-primary);
    color: #fff;
    padding: 0.5rem 0.875rem;
    min-width: 60px;
  }

  .event-month {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-family: var(--font-body);
  }

  .event-day {
    display: block;
    font-size: 1.75rem;
    font-family: var(--font-display);
    font-weight: 700;
    line-height: 1;
  }

  .event-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-primary);
    margin-bottom: 0.375rem;
  }

  .event-meta {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
    font-style: italic;
  }

  .event-body {
    font-size: 0.9375rem;
    color: var(--color-text);
  }

  .no-events {
    text-align: center;
    color: var(--color-text-muted);
    font-style: italic;
    max-width: 520px;
    margin: 0 auto;
  }

  @media (max-width: 580px) {
    .event-card {
      flex-direction: column;
      gap: 1rem;
    }

    .event-date {
      align-self: flex-start;
    }
  }
</style>
