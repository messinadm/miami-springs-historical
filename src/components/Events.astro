---
import { getCollection } from 'astro:content';

const events = await getCollection('events');
const sorted = events.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const rendered = await Promise.all(
  sorted.map(async (event) => {
    const { Content } = await event.render();
    return { data: event.data, id: event.id, Content };
  })
);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
---

<section id="events" class="events-section">
  <div class="container">
    <h2 class="section-title">Events</h2>
    <div class="divider"></div>

    {rendered.length > 0 ? (
      <ul class="events-list">
        {rendered.map(({ data, Content }) => (
          <li class="event-card">
            <div class="event-date">
              <span class="event-month">
                {data.date.toLocaleDateString('en-US', { month: 'short' })}
              </span>
              <span class="event-day">
                {data.date.toLocaleDateString('en-US', { day: '2-digit' })}
              </span>
            </div>
            <div class="event-info">
              <h3 class="event-title">{data.title}</h3>
              <p class="event-meta">
                <time datetime={data.date.toISOString()}>{formatDate(data.date)}</time>
                {data.location && <> &mdash; {data.location}</>}
              </p>
              <div class="event-body">
                <Content />
              </div>
            </div>
          </li>
        ))}
      </ul>
    ) : (
      <p class="no-events">
        No events scheduled at this time. Follow us on Facebook for the latest announcements.
      </p>
    )}
  </div>
</section>

<style>
  .events-section {
    padding: 5rem 0;
    background-color: var(--color-bg-alt);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 2.25rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
    text-align: center;
  }

  .divider {
    width: 60px;
    height: 3px;
    background-color: var(--color-secondary);
    margin: 0 auto 3rem;
  }

  .events-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 780px;
    margin: 0 auto;
  }

  .event-card {
    display: flex;
    gap: 2rem;
    background-color: var(--color-bg);
    border: 1px solid var(--color-secondary);
    padding: 1.75rem 2rem;
    align-items: flex-start;
  }

  .event-date {
    flex-shrink: 0;
    text-align: center;
    background-color: var(--color-primary);
    color: #fff;
    padding: 0.5rem 0.875rem;
    min-width: 60px;
  }

  .event-month {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-family: var(--font-body);
  }

  .event-day {
    display: block;
    font-size: 1.75rem;
    font-family: var(--font-display);
    font-weight: 700;
    line-height: 1;
  }

  .event-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-text);
    margin-bottom: 0.375rem;
  }

  .event-meta {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
    font-style: italic;
  }

  .event-body {
    font-size: 0.9375rem;
    color: var(--color-text);
  }

  .no-events {
    text-align: center;
    color: var(--color-text-muted);
    font-style: italic;
    max-width: 520px;
    margin: 0 auto;
  }

  @media (max-width: 580px) {
    .event-card {
      flex-direction: column;
      gap: 1rem;
    }

    .event-date {
      align-self: flex-start;
    }
  }
</style>
