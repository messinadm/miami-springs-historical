---
import generalSettings from '../data/general.json';

const fbUrl = generalSettings.facebook_url;
const encodedUrl = encodeURIComponent(fbUrl);
---

<section id="connect" class="fb-section">
  <div class="container">
    <h2 class="section-title"><a href="#connect">Connect With Us</a></h2>
    <div class="divider"></div>
    <p class="fb-intro">
      Follow our Facebook page for announcements, photos, and community updates.
    </p>
    <div class="fb-layout">
      <div class="fb-embed-wrap">
        <iframe
          src={`https://www.facebook.com/plugins/page.php?href=${encodedUrl}&tabs=timeline&width=500&height=600&small_header=false&adapt_container_width=true&hide_cover=false&show_facepile=true&app_id=1241743530894906`}
          width="500"
          height="600"
          style="border:none;overflow:hidden;max-width:100%;width:100%"
          scrolling="no"
          frameborder="0"
          allowfullscreen="true"
          allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
          loading="lazy"
        ></iframe>
      </div>
      <div class="fb-side">
        <h3>Miami Springs Historical Society</h3>
        <p>
          We share stories, photographs, and announcements about Miami Springs history and upcoming
          events on our Facebook page. Like and follow us to stay connected with our community.
        </p>
        <a href={fbUrl} target="_blank" rel="noopener noreferrer" class="fb-link">
          Visit our Facebook Page &rarr;
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .fb-section {
    padding: 5rem 0;
    background-color: var(--color-bg);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 5vw, 2.25rem);
    color: var(--color-primary);
    margin-bottom: 1rem;
    text-align: center;
  }

  .divider {
    width: 60px;
    height: 3px;
    background-color: var(--color-accent);
    margin: 0 auto 1.5rem;
  }

  .fb-intro {
    text-align: center;
    color: var(--color-text-muted);
    font-style: italic;
    max-width: 600px;
    margin: 0 auto 3rem;
  }

  .fb-embed-wrap {
    overflow: hidden;
    max-width: 100%;
  }

  .fb-layout {
    display: grid;
    grid-template-columns: minmax(0, 500px) 1fr;
    gap: 4rem;
    align-items: start;
  }

  .fb-side {
    padding-top: 0.5rem;
  }

  .fb-side h3 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .fb-side p {
    color: var(--color-text-muted);
    margin-bottom: 1.75rem;
    line-height: 1.75;
  }

  .fb-link {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background-color: #1877f2;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 0.875rem;
    letter-spacing: 0.03em;
    transition: background-color 0.2s;
  }

  .fb-link:hover {
    background-color: #0f5cc9;
    color: #fff;
  }

  @media (max-width: 820px) {
    .fb-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
