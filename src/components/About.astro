---
import generalSettings from '../data/general.json';
---

<section id="about" class="about-section">
  <div class="container">

    <div class="about-top">
      <h2 class="section-title"><a href="#about">About the Society</a></h2>
      <div class="divider"></div>
      <p class="about-body">{generalSettings.about}</p>
      <div class="info-cards">
        <div class="info-card">
          <h3>Visit Us</h3>
          <p>501 East Drive<br />Miami Springs, FL 33166</p>
        </div>
        <div class="info-card">
          <h3>Museum Hours</h3>
          <p>{generalSettings.hours}</p>
        </div>
        <div class="info-card">
          <h3>Contact</h3>
          <p>
            <a href={`mailto:${generalSettings.email}`}>{generalSettings.email}</a><br />
            <a href={`tel:${generalSettings.phone}`}>{generalSettings.phone}</a><br />
            {generalSettings.po_box}
          </p>
        </div>
      </div>
    </div>

    <div class="history-section">
      <div class="history-image-wrap">
        <img
          src="/curtiss-mansion-1927.jpg"
          alt="The Curtiss Mansion, circa 1927"
          class="history-image"
        />
        <p class="photo-credit">
          Fishbaugh, W.A. (William Arthur). State Archives of Florida, Florida Memory. Public Domain.
        </p>
      </div>
      <div class="history-text">
        <h2 class="section-title left">A City Born from Vision</h2>
        <div class="divider left"></div>
        <p>
          Miami Springs owes its existence to <strong>Glenn Hammond Curtiss</strong> (1878–1930),
          aviation pioneer, rival of the Wright Brothers, and holder of hundreds of patents. During
          the 1920s Florida land boom, Curtiss developed what was then called Country Club Estates,
          laying out the city's distinctive circular streets and Pueblo Revival architecture.
        </p>
        <p>
          His mansion at 500 Deer Run — designed by Martin Luther Hampton in 1925 — stands on the
          National Register of Historic Places. Curtiss, known as the "Father of Naval Aviation,"
          lived there until his death in 1930.
        </p>
        <p>
          The Curtiss Mansion remains a gathering place for the community a century later.
          <strong>We are proud to celebrate 100 years of Miami Springs.</strong>
        </p>
      </div>
    </div>

  </div>
</section>

<style>
  .about-section {
    padding: 5rem 0;
    background-color: var(--color-bg);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 5vw, 2.25rem);
    color: var(--color-primary);
    margin-bottom: 1rem;
    text-align: center;
  }

  .section-title.left {
    text-align: left;
  }

  .divider {
    width: 60px;
    height: 3px;
    background-color: var(--color-accent);
    margin: 0 auto 2.25rem;
  }

  .divider.left {
    margin-left: 0;
  }

  .about-body {
    font-size: 1.125rem;
    color: var(--color-text);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    text-align: center;
  }

  .info-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .info-card {
    background-color: var(--color-bg-alt);
    border-left: 3px solid var(--color-primary);
    padding: 1.25rem 1.5rem;
  }

  .info-card h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-primary);
    margin-bottom: 0.4rem;
  }

  .info-card p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .info-card a {
    color: var(--color-primary);
    font-size: 0.8125rem;
    overflow-wrap: break-word;
  }

  .history-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
    margin-top: 5rem;
    padding-top: 5rem;
    border-top: 1px solid var(--color-secondary);
  }

  .history-image {
    width: 100%;
    filter: sepia(35%) contrast(0.9);
    border: 4px solid var(--color-secondary);
  }

  .photo-credit {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
    font-style: italic;
  }

  .history-text p {
    margin-bottom: 1.25rem;
    color: var(--color-text);
  }

  .history-text strong {
    color: var(--color-primary);
  }

  @media (max-width: 760px) {
    .history-section {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
