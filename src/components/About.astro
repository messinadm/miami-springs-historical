---
import generalSettings from '../data/general.json';

const slides = [
  {
    id: 'founding',
    title: 'A City Born from Vision',
    image: '/glenn-curtiss-portrait.jpg',
    imageAlt: 'Portrait of Glenn Hammond Curtiss, aviation pioneer and founder of Miami Springs',
    credit: 'Harris & Ewing. Library of Congress, Prints & Photographs Division. Public Domain.',
    sepia: true,
    panel: 'right',
    theme: 'dark',
    layout: 'portrait',
    paragraphs: [
      'Miami Springs owes its existence to <strong>Glenn Hammond Curtiss</strong> and <strong>James Bright</strong>, who during the 1920s Florida land boom developed Country Club Estates — one of Florida\'s first planned communities, alongside Coral Gables and Opa-locka.',
      'Curtiss laid out the Circle and Pueblo Revival architecture. Country Club Estates was incorporated in <strong>1926</strong> and later renamed Miami Springs.',
    ],
  },
  {
    id: 'architecture',
    title: 'Architecture of the Southwest',
    image: '/curtiss-mansion-1927.jpg',
    imageAlt: 'The Curtiss Mansion, circa 1927',
    credit: 'Fishbaugh, W.A. (William Arthur). State Archives of Florida, Florida Memory. Public Domain.',
    sepia: false,
    panel: 'left',
    theme: 'light',
    paragraphs: [
      'Curtiss chose the <strong>Pueblo Revival style</strong> as the architectural theme for Miami Springs — a novelty in 1920s South Florida, drawing on the adobe traditions of the American Southwest.',
      'Thick stucco walls, flat roofs, rounded corners, and decorative vigas gave the city a look unlike anywhere else in Miami-Dade County. The <a href="https://curtissmansion.com/" target="_blank" rel="noopener noreferrer"><strong>Curtiss Mansion</strong></a> is listed on the National Register of Historic Places.',
    ],
  },
  {
    id: 'eastern',
    title: 'Home to Eastern Airlines',
    image: '/eastern-airlines-constellation.jpg',
    imageAlt: 'Eastern Airlines Super-C Constellation over Miami Beach',
    credit: 'Wikimedia Commons. Public Domain.',
    sepia: false,
    panel: 'right',
    theme: 'dark',
    panelStyle: 'bottom-bar',
    imagePosition: '50% 0%',
    paragraphs: [
      'When Eastern Air Lines relocated its operations to Miami\'s 36th Street Airport in 1935, it needed homes for hundreds of employees. <strong>Glenn Curtiss Properties</strong> offered special pricing and financing on Miami Springs homes to Eastern\'s workforce.',
      'For decades, the streets of Miami Springs were home to the pilots, mechanics, and crew who built commercial aviation between New York and Florida. The proximity to 36th Street Airport and targeted financing offers made Miami Springs the de facto hometown of Eastern\'s workforce.',
    ],
  },
  {
    id: 'centennial',
    title: 'One Hundred Years — 1926 to 2026',
    image: '/curtiss-memorial-circle.jpg',
    imageAlt: 'Glenn H. Curtiss Memorial Circle, Miami Springs, Florida',
    credit: 'Eisenthesky Productions released to public domain per file information., CC BY-SA 4.0, via Wikimedia Commons',
    sealBg: true,
    sepia: false,
    panel: 'left',
    theme: 'light',
    paragraphs: [
      'In 2026, Miami Springs marks <strong>one hundred years</strong> since its incorporation — a century of growth, resilience, and community in one of Florida\'s most distinctive cities.',
      '<strong>We invite you to be part of the centennial.</strong> Visit our museum at 501 East Drive, follow us on Facebook, and explore <a href="https://www.100miamisprings.com/" target="_blank" rel="noopener noreferrer">100miamisprings.com</a> — the official centennial site.',
    ],
  },
];
---

<section id="about" class="about-section">
  <div class="container">

    <div class="about-top">
      <h2 class="section-heading"><a href="#about">About the Society</a></h2>
      <div class="divider"></div>
      <p class="about-body">{generalSettings.about}</p>
      <div class="info-cards">
        <div class="info-card">
          <h3>Visit Us</h3>
          <p>501 East Drive<br />Miami Springs, FL 33166</p>
        </div>
        <div class="info-card">
          <h3>Museum Hours</h3>
          <p>{generalSettings.hours}</p>
        </div>
        <div class="info-card">
          <h3>Contact</h3>
          <p>
            <a href={`mailto:${generalSettings.email}`}>Email Us</a><br />
            <a href={`tel:${generalSettings.phone}`}>{generalSettings.phone}</a><br />
            {generalSettings.po_box}
          </p>
        </div>
      </div>

      <div class="museum-teaser">
        <div class="museum-teaser-image-wrap">
          <img src="/museum-exterior.jpg" alt="Miami Springs Historical Society Museum at 501 East Drive" class="museum-teaser-image" />
        </div>
        <div class="museum-teaser-text">
          <h3 class="museum-teaser-heading">Our Museum</h3>
          <div class="divider divider--left"></div>
          <p>Our museum features three rooms of exhibits spanning Miami Springs aviation history, the city's founding and growth, and the remarkable story of the Miami Battle Creek Sanitarium. Interactive multimedia, artifacts, memorabilia, and a small gift shop — all free to visit.</p>
          <a href="/museum" class="museum-teaser-link">Explore the Museum →</a>
        </div>
      </div>
    </div>

  </div>

  <div class="history-wrap" id="history">
    <div class="container">
      <h2 class="history-heading section-heading"><a href="#history">A History of Miami Springs</a></h2>
      <div class="divider"></div>
    </div>
    {slides.map((slide, i) => (
      <div class={`history-panel history-panel--${slide.theme}${slide.layout === 'portrait' ? ' history-panel--portrait' : ` history-panel--${slide.panel}`}`}>
        {slide.layout === 'portrait' ? (
          <>
            <div class="portrait-text">
              <h3 class="panel-title">{slide.title}</h3>
              <div class="panel-divider"></div>
              {slide.paragraphs.map(p => <p set:html={p} />)}
              {slide.credit && <p class="photo-credit">{slide.credit}</p>}
            </div>
            <div class="portrait-image-wrap">
              <img
                src={slide.image}
                alt={slide.imageAlt}
                class={`portrait-img${slide.sepia ? ' panel-image--sepia' : ''}`}
              />
            </div>
          </>
        ) : (
          <>
            <img
              src={slide.image}
              alt={slide.imageAlt}
              class={`panel-image${slide.sepia ? ' panel-image--sepia' : ''}`}
              style={slide.imagePosition ? `object-position: ${slide.imagePosition}` : undefined}
            />
            <div class={`panel-text${slide.panelStyle ? ` panel-text--${slide.panelStyle}` : ''}${slide.sealBg ? ' panel-text--seal' : ''}`}>
              <h3 class="panel-title">{slide.title}</h3>
              <div class="panel-divider"></div>
              {slide.paragraphs.map(p => <p set:html={p} />)}
              {slide.credit && <p class="photo-credit">{slide.credit}</p>}
            </div>
          </>
        )}
        <span class="panel-counter" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
      </div>
    ))}
  </div>

</section>

<script>
  const panels = document.querySelectorAll('.history-panel');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    },
    { threshold: 0.15 }
  );
  panels.forEach(p => observer.observe(p));
</script>

<style>
  .about-section {
    padding: 5rem 0 0;
    background-color: var(--color-bg);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    color: var(--color-primary);
    margin-bottom: 1rem;
    text-align: center;
  }

  .divider {
    width: 60px;
    height: 3px;
    background-color: var(--color-accent);
    margin: 0 auto 2.5rem;
  }

  .divider--left {
    margin: 0 0 1.25rem;
  }

  .about-body {
    font-size: 1.125rem;
    color: var(--color-text);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    text-align: center;
  }

  .info-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .info-card {
    background-color: var(--color-bg-alt);
    border-left: 3px solid var(--color-primary);
    padding: 1.25rem 1.5rem;
  }

  .info-card h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-primary);
    margin-bottom: 0.4rem;
  }

  .info-card p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .info-card a {
    color: var(--color-primary);
  }

  /* ── Museum teaser ───────────────────────────────────── */

  .museum-teaser {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-secondary);
  }

  .museum-teaser-image-wrap {
    overflow: hidden;
  }

  .museum-teaser-image {
    width: 100%;
    height: 260px;
    object-fit: cover;
    display: block;
  }

  .museum-teaser-heading {
    font-family: var(--font-display);
    font-size: 1.375rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .museum-teaser-text p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .museum-teaser-link {
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 2px solid var(--color-accent);
    padding-bottom: 2px;
    transition: color 0.2s;
  }

  .museum-teaser-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .museum-teaser {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  /* ── History panels ─────────────────────────────────── */

  .history-wrap {
    margin-top: 5rem;
    border-top: 1px solid var(--color-secondary);
    padding-top: 4rem;
  }

  .history-heading {
    margin-bottom: 1rem;
  }

  /* Panel base */

  .history-panel {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: var(--color-text);
  }

  /* Full-bleed image */

  .panel-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .panel-image--sepia {
    filter: sepia(40%) contrast(0.9);
  }

  @keyframes kenburns {
    from { transform: scale(1); }
    to   { transform: scale(1.06); }
  }

  .history-panel.is-visible .panel-image {
    animation: kenburns 15s ease-out forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .history-panel.is-visible .panel-image {
      animation: none;
    }
  }

  /* Text overlay */

  .panel-text {
    position: absolute;
    bottom: 2.5rem;
    width: 46%;
    padding: 2rem 2.5rem;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .history-panel--left  .panel-text { left:  3rem; }
  .history-panel--right .panel-text { right: 3rem; }

  .panel-text--bottom-bar {
    left: 0 !important;
    right: 0 !important;
    bottom: 0;
    width: 100%;
    padding: 1.5rem 3rem;
  }

  .history-panel--dark  .panel-text { background: var(--color-overlay-dark); }
  .history-panel--light .panel-text { background: var(--color-overlay-light); }

  .panel-text--seal {
    overflow: hidden;
  }

  .panel-text--seal::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('/miami-springs-seal.png');
    background-repeat: no-repeat;
    background-position: center;
    background-size: 65%;
    opacity: 0.13;
    pointer-events: none;
  }

  /* Portrait layout */

  .history-panel--portrait {
    display: flex;
    align-items: center;
    background-color: var(--color-text);
    padding: 3rem 6rem;
    gap: 4rem;
  }

  .portrait-text {
    flex: 1;
    min-width: 0;
  }

  .history-panel--portrait .panel-title { color: var(--color-bg); }
  .history-panel--portrait p { color: var(--color-panel-text-light); font-size: 0.9375rem; line-height: 1.7; margin-bottom: 0.75rem; }
  .history-panel--portrait p:last-child { margin-bottom: 0; }
  .history-panel--portrait strong { color: var(--color-secondary); }
  .history-panel--portrait .panel-counter { left: 4.5rem; right: unset; }

  .portrait-image-wrap {
    flex: 0 0 38%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .portrait-img {
    max-height: calc(100% - 4rem);
    width: 100%;
    object-fit: contain;
    border: 4px solid var(--color-secondary);
  }

  /* Panel titles */

  .panel-title {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2.25vw, 1.75rem);
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .history-panel--dark  .panel-title { color: var(--color-bg); }
  .history-panel--light .panel-title { color: var(--color-primary); }

  .panel-divider {
    width: 40px;
    height: 2px;
    background-color: var(--color-accent);
    margin-bottom: 1.25rem;
  }

  .panel-text p {
    font-size: 0.9375rem;
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .panel-text p:last-child { margin-bottom: 0; }

  .history-panel--dark  .panel-text p { color: var(--color-panel-text-light); }
  .history-panel--light .panel-text p { color: var(--color-text); }

  .history-panel--dark  .panel-text strong { color: var(--color-secondary); }
  .history-panel--light .panel-text strong { color: var(--color-primary); }

  .photo-credit {
    font-size: 0.75rem !important;
    font-style: italic;
    opacity: 0.65;
    margin-top: 1rem !important;
  }

  /* Chapter counter */

  .panel-counter {
    position: absolute;
    top: 1.5rem;
    right: 2rem;
    font-family: var(--font-display);
    font-size: 0.8125rem;
    letter-spacing: 0.12em;
  }

  .history-panel--dark  .panel-counter { color: var(--color-panel-counter-light); }
  .history-panel--light .panel-counter { color: var(--color-panel-counter-dark); }

  /* ── Mobile ─────────────────────────────────────────── */

  @media (max-width: 768px) {
    .history-wrap {
      background-color: var(--color-bg);
      margin-top: 0;
      border-top: 1px solid var(--color-secondary);
      padding-top: 2.5rem;
      padding-bottom: 0;
    }

    .history-wrap .container {
      padding-bottom: 0;
    }

    .history-panel {
      aspect-ratio: unset;
      overflow: visible;
      display: flex;
      flex-direction: column;
      padding-top: 5px;
    }

    .history-panel--dark,
    .history-panel--portrait { background-color: var(--color-text); }
    .history-panel--light { background-color: var(--color-bg-alt); }

    .panel-image {
      position: relative;
      inset: unset;
      width: 100%;
      height: 55vw;
      object-fit: cover;
      animation: none !important;
    }

    .panel-text,
    .panel-text--bottom-bar {
      position: relative !important;
      inset: unset !important;
      left: unset !important;
      right: unset !important;
      bottom: unset !important;
      width: 100% !important;
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
      padding: 1.75rem 1.5rem !important;
    }

    .history-panel--dark  .panel-text { background: var(--color-text); }
    .history-panel--light .panel-text { background: var(--color-bg-alt); }

    .history-panel--portrait {
      flex-direction: column;
      padding-left: 0;
      padding-right: 0;
      padding-bottom: 0;
      gap: 0;
    }

    .portrait-image-wrap {
      order: -1;
      flex: none;
      width: 100%;
      height: 60vw;
      justify-content: unset;
    }

    .portrait-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 15%;
      border: none;
      max-height: unset;
    }

    .portrait-text {
      padding: 1.75rem 1.5rem;
      background: var(--color-text);
    }

    .panel-counter { display: none; }
  }
</style>
