---
import generalSettings from '../data/general.json';

const slides = [
  {
    id: 'founding',
    title: 'A City Born from Vision',
    image: '/glenn-curtiss-portrait.jpg',
    imageAlt: 'Portrait of Glenn Hammond Curtiss, aviation pioneer and founder of Miami Springs',
    credit: 'Harris & Ewing. Library of Congress, Prints & Photographs Division (LC-DIG-hec-18632). No known restrictions.',
    paragraphs: [
      'Miami Springs owes its existence to <strong>Glenn Hammond Curtiss</strong> and <strong>James Bright</strong>, who during the 1920s Florida land boom developed what was then called Country Club Estates — one of Florida\'s first planned communities, alongside Coral Gables and Opa-locka.',
      'Curtiss laid out the city\'s distinctive circular streets and signature Pueblo Revival architecture, incorporating a golf course and country club that still anchors the community today.',
      'Country Club Estates was officially incorporated in <strong>1926</strong> and later renamed Miami Springs in 1930.',
    ],
  },
  {
    id: 'architecture',
    title: 'Architecture of the Southwest',
    // TODO: Replace with a Florida Memory public domain image of Miami Springs Pueblo Revival homes
    // Browse: https://www.floridamemory.com/collections/photographic/?q=miami+springs+pueblo
    image: '/curtiss-mansion-entrance.jpg',
    imageAlt: 'Curtiss Mansion entrance — Pueblo Revival architecture',
    credit: '',
    paragraphs: [
      'Curtiss chose the <strong>Pueblo Revival style</strong> as the architectural theme for Miami Springs — a novelty in 1920s South Florida, drawing on the hand-crafted adobe traditions of the American Southwest.',
      'The style\'s hallmarks — thick stucco walls, flat roofs, rounded corners, and decorative vigas — gave the city a look unlike anywhere else in Miami-Dade County.',
      'Several original Pueblo Revival homes remain standing today, and the city maintains a historic preservation guide to protect them. The Glenn Curtiss Mansion is a <strong>Smithsonian-recognized National Historic Site</strong>.',
    ],
  },
  {
    id: 'aviation',
    title: 'The Father of Naval Aviation',
    // TODO: Replace with a Library of Congress public domain photo of Glenn Curtiss
    // Browse: https://www.loc.gov/photos/?q=glenn+curtiss
    image: '/curtiss-mansion-1927.jpg',
    imageAlt: 'The Curtiss Mansion, home of aviation pioneer Glenn Curtiss',
    credit: 'Fishbaugh, W.A. (William Arthur). State Archives of Florida, Florida Memory. Public Domain.',
    paragraphs: [
      '<strong>Glenn Hammond Curtiss</strong> (1878–1930) was one of the most consequential figures in early aviation — rival of the Wright Brothers, holder of hundreds of patents, and the man credited as the "Father of Naval Aviation."',
      'On July 4, 1908, he piloted the June Bug to the first publicly witnessed flight in North America. His later work on seaplanes and flying boats transformed naval warfare and transatlantic aviation.',
      'Beyond flight, Curtiss shaped South Florida: he founded <strong>Miami Springs</strong>, Hialeah, and Opa-locka, built the Hialeah Racetrack, and developed the first Miami airport — leaving a legacy that stretches far beyond the cockpit.',
    ],
  },
  {
    id: 'centennial',
    title: 'One Hundred Years — 1926 to 2026',
    image: '/curtiss-mansion-entrance.jpg',
    imageAlt: 'The open entrance doors of the Curtiss Mansion, Miami Springs',
    credit: '',
    paragraphs: [
      'In 2026, Miami Springs marks <strong>one hundred years</strong> since its incorporation as Country Club Estates — a century of growth, resilience, and community in one of Florida\'s most distinctive cities.',
      'The Miami Springs Historical Society is proud to steward this legacy, preserving photographs, documents, and stories that connect residents to the remarkable vision that gave their city life.',
      '<strong>We invite you to be part of the centennial.</strong> Visit our museum at 501 East Drive, follow us on Facebook, and help us celebrate a hundred years of Miami Springs.',
    ],
  },
];
---

<section id="about" class="about-section">
  <div class="container">

    <div class="about-top">
      <h2 class="section-title"><a href="#about">About the Society</a></h2>
      <div class="divider"></div>
      <p class="about-body">{generalSettings.about}</p>
      <div class="info-cards">
        <div class="info-card">
          <h3>Visit Us</h3>
          <p>501 East Drive<br />Miami Springs, FL 33166</p>
        </div>
        <div class="info-card">
          <h3>Museum Hours</h3>
          <p>{generalSettings.hours}</p>
        </div>
        <div class="info-card">
          <h3>Contact</h3>
          <p>
            <a href={`mailto:${generalSettings.email}`}>Email Us</a><br />
            <a href={`tel:${generalSettings.phone}`}>{generalSettings.phone}</a><br />
            {generalSettings.po_box}
          </p>
        </div>
      </div>
    </div>

    <div class="history-slider-wrap">
      <div class="slider-border-top"></div>

      <div class="embla">
        <div class="embla__viewport">
          <div class="embla__container">
            {slides.map((slide) => (
              <div class="embla__slide">
                <div class="slide">
                  <div class="slide-image-wrap">
                    <img src={slide.image} alt={slide.imageAlt} class="slide-image" />
                    {slide.credit && <p class="photo-credit">{slide.credit}</p>}
                  </div>
                  <div class="slide-text">
                    <h2 class="slide-title">{slide.title}</h2>
                    <div class="slide-divider"></div>
                    {slide.paragraphs.map(p => <p set:html={p} />)}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <button class="slider-btn slider-btn--prev" id="prevBtn" aria-label="Previous slide">&#8592;</button>
        <button class="slider-btn slider-btn--next" id="nextBtn" aria-label="Next slide">&#8594;</button>
      </div>
    </div>

  </div>
</section>

<script>
  import EmblaCarousel from 'embla-carousel';

  const viewport = document.querySelector('.embla__viewport') as HTMLElement;
  const embla = EmblaCarousel(viewport, { loop: true });

  document.getElementById('prevBtn')!.addEventListener('click', () => embla.scrollPrev());
  document.getElementById('nextBtn')!.addEventListener('click', () => embla.scrollNext());
</script>

<style>
  .about-section {
    padding: 5rem 0;
    background-color: var(--color-bg);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 5vw, 2.25rem);
    color: var(--color-primary);
    margin-bottom: 1rem;
    text-align: center;
  }

  .divider {
    width: 60px;
    height: 3px;
    background-color: var(--color-accent);
    margin: 0 auto 2.25rem;
  }

  .about-body {
    font-size: 1.125rem;
    color: var(--color-text);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    text-align: center;
  }

  .info-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .info-card {
    background-color: var(--color-bg-alt);
    border-left: 3px solid var(--color-primary);
    padding: 1.25rem 1.5rem;
  }

  .info-card h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-primary);
    margin-bottom: 0.4rem;
  }

  .info-card p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .info-card a {
    color: var(--color-primary);
  }

  /* Slider */

  .history-slider-wrap {
    margin-top: 5rem;
    background-color: var(--color-bg-alt);
  }

  .slider-border-top {
    border-top: 1px solid var(--color-secondary);
    margin-bottom: 4rem;
  }

  .embla__viewport {
    overflow: hidden;
    width: 100%;
  }

  .embla__container {
    display: flex;
  }

  .embla__slide {
    flex: 0 0 100%;
    min-width: 0;
  }

  .slide {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
    padding: 3rem 4rem;
  }

  .slide-image {
    width: 100%;
    filter: sepia(35%) contrast(0.9);
    border: 4px solid var(--color-secondary);
  }

  .photo-credit {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
    font-style: italic;
  }

  .slide-title {
    font-family: var(--font-display);
    font-size: 2.25rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .slide-divider {
    width: 60px;
    height: 3px;
    background-color: var(--color-secondary);
    margin-bottom: 1.75rem;
  }

  .slide-text p {
    margin-bottom: 1.25rem;
    color: var(--color-text);
  }

  .slide-text strong {
    color: var(--color-primary);
  }

  /* Controls */

  .embla {
    position: relative;
  }

  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: rgba(250, 246, 240, 0.9);
    border: 2px solid var(--color-secondary);
    color: var(--color-primary);
    font-size: 1.5rem;
    width: 3rem;
    height: 3rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, background-color 0.2s;
    z-index: 10;
  }

  .slider-btn--prev { left: -1.5rem; }
  .slider-btn--next { right: -1.5rem; }

  .slider-btn:hover {
    border-color: var(--color-primary);
    background-color: var(--color-bg-alt);
  }

  @media (max-width: 760px) {
    .slide {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
