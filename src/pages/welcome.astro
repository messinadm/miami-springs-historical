---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import generalSettings from '../data/general.json';
import { useTranslations } from '../i18n/utils';
const t = useTranslations(Astro.currentLocale);
---

<Layout
  title={t('membership.meta_title')}
  description={t('membership.meta_description')}
  noindex={true}
>
  <Nav />

  <main id="main-content" class="welcome" aria-labelledby="welcome-heading">
    <div class="image-wrap">
      <img
        src="/miami-springs-motorcoach.jpg"
        alt="A vintage automobile and motor coach parked before a Pueblo Revival building among palm trees in early Miami Springs"
        class="bg-image"
        loading="eager"
        fetchpriority="high"
      />
      <div class="overlay"></div>
    </div>

    <div class="content">
      <p class="eyebrow">{t('membership.eyebrow')}</p>
      <h1 id="welcome-heading">{t('membership.heading')}</h1>
      <div class="divider"></div>
      <p class="body">{t('membership.body')}</p>

      <nav class="actions" aria-label="Next steps">
        <a href="/museum" class="btn-ghost">{t('membership.museum_cta')}</a>
        <a href={generalSettings.facebook_url} target="_blank" rel="noopener noreferrer" class="btn-ghost">{t('membership.facebook_cta')}</a>
        <a href="/" class="btn-ghost">{t('membership.home_cta')}</a>
      </nav>
    </div>

    <p class="photo-credit">{t('membership.photo_credit')}</p>
  </main>

  <Footer />
</Layout>

<style>
  .welcome {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .image-wrap {
    position: absolute;
    inset: 0;
  }

  .bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: sepia(30%) contrast(0.95);
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      var(--color-overlay-gradient-mid) 0%,
      var(--color-overlay-gradient-end) 60%,
      var(--color-overlay-gradient-end) 100%
    );
  }

  .content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2rem;
    max-width: 720px;
  }

  .eyebrow {
    font-family: var(--font-body);
    font-size: clamp(0.75rem, 1.5vw, 0.8125rem);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-eyebrow);
    margin-bottom: 1rem;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.7);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3.75rem);
    color: var(--color-white);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.25rem;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.6);
  }

  .divider {
    width: 60px;
    height: 3px;
    background-color: var(--color-eyebrow);
    margin: 0 auto 2.5rem;
  }

  .body {
    font-family: var(--font-body);
    font-size: clamp(0.9375rem, 2vw, 1.125rem);
    color: var(--color-panel-text-light);
    line-height: 1.75;
    margin-bottom: 2.5rem;
    max-width: 580px;
    margin-left: auto;
    margin-right: auto;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.6);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .btn-ghost {
    display: inline-block;
    padding: 0.75rem 2rem;
    background-color: transparent;
    color: var(--color-white);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 2px solid var(--color-btn-ghost-border);
    transition: background-color 0.2s, border-color 0.2s;
  }

  .btn-ghost:hover {
    background-color: var(--color-btn-ghost-hover);
    border-color: var(--color-white);
  }

  .photo-credit {
    position: absolute;
    bottom: 0.5rem;
    right: 1rem;
    z-index: 1;
    max-width: min(60%, 30rem);
    text-align: right;
    line-height: 1.4;
    font-size: 0.75rem;
    font-style: italic;
    color: var(--color-photo-credit);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.7);
  }

  @media (max-width: 600px) {
    .actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
