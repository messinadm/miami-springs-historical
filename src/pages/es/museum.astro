---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import generalSettings from '../../data/general.json';
import { useTranslations } from '../../i18n/utils';
const t = useTranslations(Astro.currentLocale);
---

<Layout
  title={t('museum.meta_title')}
  description={t('museum.meta_description')}
  lang="es"
>
  <div class="page-wrap">
    <header class="page-header">
      <a href="/es" class="back-link">{t('museum.back')}</a>
      <h1 class="page-title">{t('museum.heading')}</h1>
      <p class="page-intro">{t('museum.intro')}</p>
    </header>

    <main id="main-content" class="page-main">

      <!-- Visit Info -->
      <section class="visit-section" aria-labelledby="visit-heading">
        <h2 id="visit-heading" class="section-heading">{t('museum.visit_heading')}</h2>
        <div class="divider"></div>
        <div class="visit-cards">
          <div class="visit-card">
            <h3>{t('museum.visit_hours')}</h3>
            <p>{t('footer.hours')}</p>
          </div>
          <div class="visit-card">
            <h3>{t('museum.visit_location')}</h3>
            <p>501 East Drive<br />Miami Springs, FL 33166</p>
          </div>
          <div class="visit-card">
            <h3>{t('museum.visit_admission')}</h3>
            <p>{t('museum.visit_admission_text')}</p>
          </div>
          <div class="visit-card">
            <h3>{t('museum.visit_parking')}</h3>
            <p>{t('museum.visit_parking_text')}</p>
          </div>
        </div>
      </section>

      <!-- Exhibits -->
      <section class="exhibits-section" aria-labelledby="exhibits-heading">
        <h2 id="exhibits-heading" class="section-heading">{t('museum.exhibits_heading')}</h2>
        <div class="divider"></div>

        <div class="exhibit">
          <div class="exhibit-text">
            <h3>{t('museum.exhibit_1_title')}</h3>
            <p>{t('museum.exhibit_1_body')}</p>
          </div>
          <div class="exhibit-image-wrap">
            <img src="/museum-homestead.jpg" alt="Historical exhibit on the City of Miami Springs" class="exhibit-image" />
          </div>
        </div>

        <div class="exhibit exhibit--reverse">
          <div class="exhibit-text">
            <h3>{t('museum.exhibit_2_title')}</h3>
            <p>{t('museum.exhibit_2_body')}</p>
          </div>
          <div class="exhibit-image-wrap">
            <img src="/museum-eastern.jpg" alt="Stewardess uniforms and airline memorabilia exhibit" class="exhibit-image exhibit-image--portrait" />
          </div>
        </div>

        <div class="exhibit">
          <div class="exhibit-text">
            <h3>{t('museum.exhibit_3_title')}</h3>
            <p set:html={t('museum.exhibit_3_body')} />
          </div>
          <div class="exhibit-image-wrap">
            <img src="/curtiss-school-1912.jpg" alt="Glenn Curtiss flight school students, 1912" class="exhibit-image exhibit-image--portrait exhibit-image--offset" />
          </div>
        </div>

        <div class="exhibit exhibit--reverse">
          <div class="exhibit-text">
            <h3>{t('museum.exhibit_4_title')}</h3>
            <p>{t('museum.exhibit_4_body')}</p>
          </div>
          <div class="exhibit-image-wrap">
            <img src="/museum-panam.jpg" alt="Pan American Airways Dinner Key diorama exhibit" class="exhibit-image exhibit-image--portrait" />
          </div>
        </div>

        <div class="exhibit">
          <div class="exhibit-text">
            <h3>{t('museum.exhibit_5_title')}</h3>
            <p>{t('museum.exhibit_5_body')}</p>
            <a href="https://www.miamisprings-fl.gov/community/page/hotel-country-club-fairhavens" target="_blank" rel="noopener noreferrer" class="exhibit-link">{t('museum.exhibit_5_link')}</a>
          </div>
          <div class="exhibit-image-wrap">
            <img src="/kellogg-sanitarium-1928.jpg" alt="Kellogg Southern Sanitarium, Miami Springs, 1928" class="exhibit-image" />
            <p class="photo-credit">Jesse S. Wooley, 1928. Floyd and Marion Rinhart Photograph Collection, University of Miami Libraries. Public domain.</p>
          </div>
        </div>

        <div class="exhibit exhibit--reverse">
          <div class="exhibit-text">
            <h3>{t('museum.exhibit_6_title')}</h3>
            <p>{t('museum.exhibit_6_body')}</p>
          </div>
          <div class="exhibit-image-wrap">
            <img src="/museum-flamingos.jpg" alt="Flamingo flamboyance exhibit" class="exhibit-image exhibit-image--portrait" />
          </div>
        </div>
      </section>

      <!-- Gift Shop & Artifact Donations -->
      <div class="bottom-pair">
        <section class="gift-section" aria-labelledby="gift-heading">
          <h2 id="gift-heading" class="section-heading">{t('museum.gift_heading')}</h2>
          <div class="divider"></div>
          <p>{t('museum.gift_body')}</p>
        </section>

        <section class="donate-section" aria-labelledby="donate-heading">
          <h2 id="donate-heading" class="section-heading">{t('museum.donate_heading')}</h2>
          <div class="divider"></div>
          <p>{t('museum.donate_body')} <a href={`mailto:${generalSettings.email}`}>{t('museum.donate_contact')}</a> {t('museum.donate_suffix')}</p>
        </section>
      </div>

      <!-- Satellite Locations -->
      <section class="satellite-section" aria-labelledby="satellite-heading">
        <h2 id="satellite-heading" class="section-heading">{t('museum.satellite_heading')}</h2>
        <div class="divider"></div>
        <p class="satellite-intro">{t('museum.satellite_intro')}</p>
        <div class="satellite-cards">
          <div class="satellite-card">
            <div class="satellite-card-text">
              <h3>{t('museum.satellite_1_title')}</h3>
              <p set:html={t('museum.satellite_1_body')} />
            </div>
          </div>
          <div class="satellite-card">
            <div class="satellite-card-text">
              <h3>{t('museum.satellite_2_title')}</h3>
              <p>{t('museum.satellite_2_body')}</p>
            </div>
          </div>
          <div class="satellite-card">
            <div class="satellite-card-text">
              <h3>{t('museum.satellite_3_title')}</h3>
              <p>{t('museum.satellite_3_body')}</p>
            </div>
          </div>
        </div>
        <p class="satellite-closing">{t('museum.satellite_closing')} <a href={`mailto:${generalSettings.email}`}>{t('museum.satellite_contact')}</a></p>
      </section>

    </main>
  </div>
  <Footer />
</Layout>

<style>
  /* Identical styles to museum.astro — shared via Layout globals where possible */
  .page-wrap { max-width: var(--max-width); margin: 0 auto; padding: 5rem 2rem 4rem; }
  .page-header { margin-bottom: 3.5rem; border-bottom: 1px solid var(--color-secondary); padding-bottom: 2.5rem; }
  .back-link { font-size: 0.8125rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-text-muted); text-decoration: none; display: inline-block; margin-bottom: 1.5rem; }
  .back-link:hover { color: var(--color-primary); }
  .page-title { font-family: var(--font-display); font-size: clamp(1.75rem, 5vw, 2.75rem); color: var(--color-primary); margin-bottom: 0.75rem; }
  .page-intro { font-size: 1rem; color: var(--color-text-muted); }
  .visit-section { margin-bottom: 3rem; }
  .visit-cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .visit-card { background-color: var(--color-bg-alt); border-left: 3px solid var(--color-primary); padding: 1.25rem 1.5rem; }
  .visit-card h3 { font-family: var(--font-display); font-size: 1rem; color: var(--color-primary); margin-bottom: 0.4rem; }
  .visit-card p { font-size: 0.9375rem; color: var(--color-text-muted); line-height: 1.6; }
  .section-heading { font-family: var(--font-display); font-size: clamp(1.25rem, 3vw, 1.75rem); color: var(--color-primary); margin-bottom: 1rem; }
  .divider { width: 60px; height: 3px; background-color: var(--color-accent); margin-bottom: 2.5rem; }
  .exhibits-section { margin-bottom: 4rem; }
  .exhibit { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; margin-bottom: 4rem; padding-bottom: 4rem; border-bottom: 1px solid var(--color-secondary); }
  .exhibit:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .exhibit--reverse { direction: rtl; }
  .exhibit--reverse > * { direction: ltr; }
  .exhibit-text h3 { font-family: var(--font-display); font-size: 1.25rem; color: var(--color-primary); margin-bottom: 0.75rem; }
  .exhibit-text p { font-size: 0.9375rem; color: var(--color-text-muted); line-height: 1.7; margin-bottom: 1rem; }
  .exhibit-link { font-size: 0.8125rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-primary); text-decoration: none; border-bottom: 2px solid var(--color-accent); padding-bottom: 2px; }
  .exhibit-link:hover { color: var(--color-accent); }
  .exhibit-image-wrap { overflow: hidden; }
  .exhibit-image { width: 100%; height: 300px; object-fit: cover; display: block; }
  .exhibit-image--portrait { height: 400px; object-fit: cover; object-position: center top; }
  .exhibit-image--offset { object-position: center 12.5%; }
  .photo-credit { font-size: 0.75rem; font-style: italic; color: var(--color-text-muted); margin-top: 0.5rem; }
  .bottom-pair { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; margin-bottom: 4rem; }
  .gift-section, .donate-section { margin-bottom: 0; }
  .gift-section p, .donate-section p { font-size: 1rem; color: var(--color-text-muted); line-height: 1.7; max-width: 480px; }
  .donate-section a { color: var(--color-primary); }
  .satellite-section { margin-bottom: 4rem; }
  .satellite-intro { font-size: 1rem; color: var(--color-text-muted); line-height: 1.7; margin-bottom: 2rem; }
  .satellite-closing { font-size: 1rem; color: var(--color-text-muted); margin-top: 2rem; }
  .satellite-closing a { color: var(--color-primary); }
  .satellite-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; }
  .satellite-card { background-color: var(--color-bg-alt); border-left: 3px solid var(--color-primary); overflow: hidden; }
  .satellite-card-text { padding: 1.25rem 1.5rem; }
  .satellite-card h3 { font-family: var(--font-display); font-size: 1rem; color: var(--color-primary); margin-bottom: 0.4rem; }
  .satellite-card p { font-size: 0.9375rem; color: var(--color-text-muted); line-height: 1.6; }
  @media (max-width: 768px) {
    .visit-cards { grid-template-columns: 1fr; }
    .exhibit { grid-template-columns: 1fr; gap: 1.5rem; }
    .exhibit--reverse { direction: ltr; }
    .exhibit-image, .exhibit-image--portrait { height: 240px; }
    .bottom-pair { grid-template-columns: 1fr; gap: 2rem; }
  }
  @media (max-width: 480px) {
    .exhibit-image { height: 200px; }
    .exhibit-image--portrait { height: 220px; }
  }
</style>
