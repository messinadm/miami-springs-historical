---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { resourceSections } from '../../data/resources';
import { useTranslations } from '../../i18n/utils';
const t = useTranslations(Astro.currentLocale);
---

<Layout
  title={t('resources.meta_title')}
  description={t('resources.meta_description')}
  lang="es"
>
  <Nav />
  <div class="page-wrap">
    <header class="page-header" role="banner">
      <a href="/es" class="back-link">{t('resources.back')}</a>
      <h1 class="page-title">{t('resources.heading')}</h1>
      <p class="page-intro">{t('resources.intro')}</p>
    </header>

    <main id="main-content" class="page-main">
      {resourceSections.map((section, i) => (
        <section class="resource-section" aria-labelledby={`resource-heading-${i}`}>
          <h2 id={`resource-heading-${i}`} class="section-heading">{t(`resources.section_${section.key}`)}</h2>
          <ul class="resource-list">
            {section.links.map(link => (
              <li class="resource-item">
                <a href={link.url} target="_blank" rel="noopener noreferrer" class="resource-link">{link.label}</a>
                {link.note && <p class="resource-note">{link.note}</p>}
              </li>
            ))}
          </ul>
        </section>
      ))}
    </main>
  </div>
  <Footer />
</Layout>

<style>
  .page-wrap {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 5rem 2rem 4rem;
  }

  .page-header {
    margin-bottom: 3.5rem;
    border-bottom: 1px solid var(--color-secondary);
    padding-bottom: 2.5rem;
  }

  .back-link {
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .page-intro {
    font-size: 1rem;
    color: var(--color-text-muted);
  }

  .resource-section {
    margin-bottom: 3rem;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    color: var(--color-primary);
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-accent);
    display: inline-block;
  }

  .resource-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .resource-item {
    padding-left: 1rem;
    border-left: 2px solid var(--color-bg-alt);
  }

  .resource-link {
    font-size: 1rem;
    color: var(--color-primary);
    border-bottom: 1px solid var(--color-secondary);
    padding-bottom: 1px;
  }

  .resource-link:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .resource-note {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
    font-style: italic;
  }
</style>
