---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/utils';
const t = useTranslations(Astro.currentLocale);
---

<Layout
  title={t('not_found.meta_title')}
  description={t('not_found.meta_description')}
>
  <main id="main-content" class="not-found">
    <div class="image-wrap">
      <img
        src="/circle-park-1926.jpg"
        alt="Cars entering Country Club Estates, Miami Springs, February 1926"
        class="bg-image"
      />
      <div class="overlay"></div>
    </div>

    <div class="content">
      <p class="eyebrow">{t('not_found.eyebrow')}</p>
      <h1>{t('not_found.heading')}</h1>
      <p class="body">{t('not_found.body')}</p>
      <a href="/" class="btn">{t('not_found.cta')}</a>
      <p class="photo-credit">
        {t('not_found.photo_credit')}
        <a href="https://www.floridamemory.com/items/show/165449" target="_blank" rel="noopener noreferrer">State Archives of Florida, Florida Memory.</a> Public Domain.
      </p>
    </div>
  </main>
</Layout>

<style>
  .not-found {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .image-wrap {
    position: absolute;
    inset: 0;
  }

  .bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: sepia(40%) contrast(0.85);
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(42, 26, 14, 0.6) 0%,
      rgba(42, 26, 14, 0.75) 60%,
      rgba(42, 26, 14, 0.88) 100%
    );
  }

  .content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2rem;
    max-width: 680px;
  }

  .eyebrow {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-secondary);
    margin-bottom: 1.25rem;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.7);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3.75rem);
    color: var(--color-white);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.6);
  }

  .body {
    font-family: var(--font-body);
    font-size: clamp(0.9375rem, 2vw, 1.125rem);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.75;
    margin-bottom: 2.5rem;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.6);
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    background-color: var(--color-primary);
    color: var(--color-white);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 2px solid var(--color-primary);
    transition: background-color 0.2s, border-color 0.2s;
  }

  .btn:hover {
    background-color: var(--color-primary-dark);
    border-color: var(--color-primary-dark);
    color: var(--color-white);
  }

  .photo-credit {
    margin-top: 3rem;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    font-style: italic;
    line-height: 1.5;
  }

  .photo-credit a {
    color: rgba(255, 255, 255, 0.6);
  }

  .photo-credit a:hover {
    color: rgba(255, 255, 255, 0.9);
  }
</style>
